extends ../layout

block content
  .page-header
    h1.pixel-text HOMEPAGE SETTINGS
    a.btn.btn-neon-outline.me-2(href='/admin/guide') Admin Guide
    a.btn.btn-neon-outline(href='/admin') <- Admin Dashboard

  .row.justify-content-center.mt-2
    .col-lg-8

      form(method='POST', action='/admin/homepage', enctype='multipart/form-data')
        input(type='hidden', name='_csrf', value=_csrf)

        .md-card.mb-4

          h3.section-label Hero Text

          .mb-4
            label.md-label(for='heroLine1') Headline — line 1
            input.md-input(
              type='text', id='heroLine1', name='heroLine1',
              value=(settings.heroLine1 || ''),
              maxlength=limits.heroLine1,
              placeholder='SURF THE WAVE.')
            .d-flex.justify-content-between.mt-1
              span.small.text-muted Leave blank to keep the default text.
              span.small.text-muted
                span= (settings.heroLine1 || '').length
                |  / #{limits.heroLine1}

          .mb-4
            label.md-label(for='heroLine2') Headline — line 2
            input.md-input(
              type='text', id='heroLine2', name='heroLine2',
              value=(settings.heroLine2 || ''),
              maxlength=limits.heroLine2,
              placeholder='BUILD THE FUTURE.')
            .d-flex.justify-content-between.mt-1
              span.small.text-muted Leave blank to keep the default text.
              span.small.text-muted
                span= (settings.heroLine2 || '').length
                |  / #{limits.heroLine2}

          .mb-4
            label.md-label(for='heroSubtitle') Subtitle (one-liner below headline)
            input.md-input(
              type='text', id='heroSubtitle', name='heroSubtitle',
              value=(settings.heroSubtitle || ''),
              maxlength=limits.heroSubtitle,
              placeholder='Canonical Madrid Engineering Sprint — AI Hackathon')
            .d-flex.justify-content-between.mt-1
              span.small.text-muted Leave blank to keep the default text.
              span.small.text-muted
                span= (settings.heroSubtitle || '').length
                |  / #{limits.heroSubtitle}

          .mb-4
            label.md-label(for='heroDescription') Description paragraph
            textarea.md-input(
              id='heroDescription', name='heroDescription',
              rows='5',
              maxlength=limits.heroDescription,
              placeholder='Every engineer suddenly got access to superpowers...')= (settings.heroDescription || '')
            .d-flex.justify-content-between.mt-1
              span.small.text-muted
                | Markdown: <strong>**bold**</strong>, <em>*italic*</em>, <code>[text](url)</code> — e.g. <code>[Get started -&gt;](/get-started)</code>
              span.small.text-muted
                span#desc-char-count= (settings.heroDescription || '').length
                |  / #{limits.heroDescription}

          h3.section-label.mt-4 Hero Image

          .mb-3
            p.md-label Current image
            - const currentSrc = settings.heroImage || '/images/megademo-wave.jpg'
            img.img-fluid.mb-2(
              src=currentSrc,
              alt='Current hero image',
              style='max-height:200px; border-radius:4px; opacity:0.9;')
            if settings.heroImage
              p.small.text-muted Custom uploaded image.
            else
              p.small.text-muted Using the default image.

          if settings.heroImage
            .mb-4
              label.checkbox-item
                input(type='checkbox', name='removeHeroImage', value='1')
                span Remove custom image and revert to default

          .mb-4
            label.md-label(for='heroImageFile') Upload new image
            input.md-input(
              type='file', id='heroImageFile', name='heroImage',
              accept='.jpg,.jpeg,.png,.webp')
            .mt-1
              span.small.text-muted Max 3 MB · JPG, PNG, WebP
              br
              span.small.text-muted
                | Recommended: <strong>16:9 aspect ratio</strong>, at least <strong>1 200 × 675 px</strong>. Uploading replaces the current image.

          button.btn.btn-neon-cyan(type='submit') Save Homepage Settings

block scripts
  script(nonce=cspNonce).
    [
      ['heroLine1',    document.querySelector('input[name="heroLine1"]'),    null],
      ['heroLine2',    document.querySelector('input[name="heroLine2"]'),    null],
      ['heroSubtitle', document.querySelector('input[name="heroSubtitle"]'), null],
      [null,           document.querySelector('#heroDescription'),           document.getElementById('desc-char-count')],
    ].forEach(([, el, counter]) => {
      if (!el) return;
      const row = el.closest('.mb-4');
      const span = counter || row.querySelector('.d-flex span.small.text-muted:last-child span');
      if (!span) return;
      el.addEventListener('input', () => { span.textContent = el.value.length; });
    });
