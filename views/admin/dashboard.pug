extends ../layout

block head
  script(src='https://cdn.jsdelivr.net/npm/chart.js@4.5.1/dist/chart.umd.min.js', integrity='sha384-jb8JQMbMoBUzgWatfe6COACi2ljcDdZQ2OxczGA3bGNeWe+6DChMTBJemed7ZnvJ', crossorigin='anonymous', nonce=cspNonce)

block content
  .page-header
    h1.pixel-text ADMIN DASHBOARD
    a.btn.btn-neon-outline.position-absolute.start-50.translate-middle-x(href='/admin/guide') Admin Guide

  .stats-grid
    .stat-card
      .stat-number= stats.totalProjects
      .stat-label Projects
    .stat-card
      .stat-number= stats.totalVotes
      .stat-label Votes
    .stat-card
      .stat-number= stats.totalUsers
      .stat-label Users
    .stat-card.finalist
      .stat-number= stats.finalists
      .stat-label Finalists

  .row.mt-4
    .col-md-6
      .md-card
        h3.section-label Categories
        canvas#categoryChart
    .col-md-6
      .md-card
        h3.section-label Event Dates
        form(method='POST', action='/admin/settings')
          input(type='hidden', name='_csrf', value=_csrf)
          input(type='hidden', name='section', value='dates')
          .mb-3
            label.md-label Hackathon Start
            input.md-input(type='datetime-local', name='hackStart',
              data-utc=(settings.hackathonStart || ''))
            p.text-muted.small.mt-1
              strong When set, project registration is disabled until this time.
          .mb-3
            label.md-label Submission Deadline
            input.md-input(type='datetime-local', name='subDeadline',
              data-utc=(settings.submissionDeadline || ''))
          .mb-3
            label.md-label MegaDemo Date &amp; Time
            input.md-input(type='datetime-local', name='megaDatetime',
              data-utc=(settings.megademoDate || ''))
          button.btn.btn-neon-cyan(type='submit') Save Dates
        #admin-countdown-status.mt-3.small.text-muted(
          data-hackathon-start=(settings.hackathonStart || ''),
          data-deadline=(settings.submissionDeadline || ''),
          data-megademo=(settings.megademoDate || ''))
          | Loading countdown status…

      .md-card.mt-3
        h3.section-label Mattermost
        form(method='POST', action='/admin/settings')
          input(type='hidden', name='_csrf', value=_csrf)
          input(type='hidden', name='section', value='mattermost')
          .mb-3
            label.md-label Webhook URL
            input.md-input(type='url', name='mattermostWebhook', value=(settings.mattermostWebhook || ''), placeholder='https://mattermost.../hooks/...')
          button.btn.btn-neon-cyan(type='submit') Save Webhook
        form.mt-2(method='POST', action='/admin/mattermost/send')
          input(type='hidden', name='_csrf', value=_csrf)
          button.btn.btn-neon-outline(type='submit') Send Summary Now

      .md-card.mt-3
        h3.section-label Visualization Sync
        p.small.text-muted Fetch latest project cluster visualization from GitHub.
        form(method='POST', action='/admin/visualize/sync')
          input(type='hidden', name='_csrf', value=_csrf)
          button.btn.btn-neon-outline(type='submit') Sync Now

  .md-card.mt-4
    h3.section-label Announcement Banner
    form(method='POST', action='/admin/settings')
      input(type='hidden', name='_csrf', value=_csrf)
      input(type='hidden', name='section', value='banner')
      .mb-2
        label.md-label Banner Text
        textarea.md-input(name='announcementBanner', rows='3', maxlength='500',
          placeholder='Leave empty to hide banner. Markdown supported.')= (settings.announcementBanner || '')
        .d-flex.justify-content-between.mt-1
          span.small.text-muted Markdown supported. Empty = no banner.
          span.small.text-muted
            span#banner-char-count= (settings.announcementBanner || '').length
            |  / 500
      button.btn.btn-neon-cyan(type='submit') Save Banner

  .row.mt-4
    .col-md-6
      .d-flex.flex-column.gap-2
        a.btn.btn-neon-outline(href='/admin/projects') Manage Projects
        a.btn.btn-neon-outline(href='/admin/users') Manage Users
        a.btn.btn-neon-outline(href='/admin/teams') Manage Teams
        a.btn.btn-neon-outline(href='/admin/tags') Manage Tags &amp; AI Tools
    .col-md-6
      .d-flex.flex-column.gap-2
        a.btn.btn-neon-outline(href='/admin/homepage') Homepage Settings
        a.btn.btn-neon-outline(href='/admin/activity-log') Activity Log
        button.btn.btn-neon-outline(type='button', data-bs-toggle='modal', data-bs-target='#exportModal') Export CSV

  .md-card.mt-4
    h3.section-label Recent Projects
    table.md-table
      thead
        tr
          th Title
          th Category
          th Status
          th Created
      tbody
        each p in recentProjects
          tr
            td
              a(href='/projects/' + p.slug)= p.title
            td= p.category
            td
              - const safeStatus = ['draft','submitted','finalist'].includes(p.status) ? p.status : 'draft'
              span(class='status-badge status-' + safeStatus)= p.status
            td= new Date(p.createdAt).toISOString().slice(0, 10)

  // Test Login
  if testLoginToken
    .md-card.mt-4
      h3.section-label Test Login
      p.text-muted.mb-3
        | Log in as a synthetic test user without GitHub OAuth (POST only).
        | Revoke access by removing the <code>TEST_LOGIN_TOKEN</code> environment variable.
      .d-flex.flex-column.gap-2
        .d-flex.align-items-center.gap-2
          form(method='POST', action='/auth/test-login', style='display:inline')
            input(type='hidden', name='token', value=testLoginToken)
            input(type='hidden', name='role', value='participant')
            input(type='hidden', name='_csrf', value=_csrf)
            button.btn.btn-sm.btn-neon-outline(type='submit') Login as participant
          button.btn.btn-xs.btn-neon-outline.copy-btn(type='button', data-url='curl -X POST ' + baseUrl + '/auth/test-login -d "token=' + testLoginToken + '&role=participant"') Copy curl
        .d-flex.align-items-center.gap-2
          form(method='POST', action='/auth/test-login', style='display:inline')
            input(type='hidden', name='token', value=testLoginToken)
            input(type='hidden', name='role', value='admin')
            input(type='hidden', name='_csrf', value=_csrf)
            button.btn.btn-sm.btn-neon-outline(type='submit') Login as admin
          button.btn.btn-xs.btn-neon-outline.copy-btn(type='button', data-url='curl -X POST ' + baseUrl + '/auth/test-login -d "token=' + testLoginToken + '&role=admin"') Copy curl

  // Danger Zone
  .md-card.mt-4.danger-zone-card
    h3.section-label !!! Danger Zone
    p.text-muted.mb-3
      | Permanently delete <strong>all projects and votes</strong> and reset configurable lists
      | (teams, AI tools, tech stack) to their default values.
      | User accounts and deadline settings are preserved.
    button.btn.btn-danger-outline(type='button', data-bs-toggle='modal', data-bs-target='#resetModal') Reset Everything to Zero

  // Reset confirmation modal
  #resetModal.modal.fade(tabindex='-1', aria-labelledby='resetModalLabel', aria-hidden='true')
    .modal-dialog.modal-dialog-centered
      .modal-content.md-modal
        .modal-header
          h5.modal-title#resetModalLabel !!! Confirm Full Reset
          button.btn-close(type='button', data-bs-dismiss='modal', aria-label='Close')
        .modal-body
          p This will permanently delete <strong>all projects and all votes</strong> and reset the configurable lists to defaults.
          p.text-muted This action cannot be undone.
          p Type <strong>RESET</strong> below to confirm:
          input#resetConfirmInput.md-input.mt-2(type='text', placeholder='RESET', autocomplete='off')
        .modal-footer(style='justify-content:space-between; align-items:center;')
          label.checkbox-item(style='cursor:pointer; font-size:0.85rem;')
            input#wipeLogs(type='checkbox', name='wipeLogs', value='1', form='resetForm')
            span Also wipe the activity log
          form#resetForm(method='POST', action='/admin/reset')
            input(type='hidden', name='_csrf', value=_csrf)
            input#resetConfirmHidden(type='hidden', name='confirm', value='')
            button.btn.btn-neon-outline(type='button', data-bs-dismiss='modal') Cancel
            button#resetSubmitBtn.btn.btn-danger-outline(type='submit', disabled) Confirm Reset

  // Export CSV modal
  #exportModal.modal.fade(tabindex='-1', aria-labelledby='exportModalLabel', aria-hidden='true')
    .modal-dialog.modal-dialog-centered.modal-dialog-scrollable
      .modal-content.md-modal
        .modal-header
          h5.modal-title#exportModalLabel Export Projects to CSV
          button.btn-close(type='button', data-bs-dismiss='modal', aria-label='Close')
        .modal-body
          .export-global-toggle
            label.checkbox-item
              input#exportSelectAll(type='checkbox', checked)
              span Select All
          //- Basic Info
          .export-group-header
            span Basic Info
            button.group-toggle(type='button', data-group='basic') Deselect
          .checkbox-grid
            label.checkbox-item
              input.export-field(type='checkbox', data-key='title', data-group='basic', checked)
              span Title
            label.checkbox-item
              input.export-field(type='checkbox', data-key='slug', data-group='basic', checked)
              span Slug
            label.checkbox-item
              input.export-field(type='checkbox', data-key='description', data-group='basic', checked)
              span Description
            label.checkbox-item
              input.export-field(type='checkbox', data-key='category', data-group='basic', checked)
              span Category
            label.checkbox-item
              input.export-field(type='checkbox', data-key='status', data-group='basic', checked)
              span Status
            label.checkbox-item
              input.export-field(type='checkbox', data-key='completionStage', data-group='basic', checked)
              span Completion Stage
          //- People & Teams
          .export-group-header
            span People &amp; Teams
            button.group-toggle(type='button', data-group='people') Deselect
          .checkbox-grid
            label.checkbox-item
              input.export-field(type='checkbox', data-key='ownerName', data-group='people', checked)
              span Owner Name
            label.checkbox-item
              input.export-field(type='checkbox', data-key='ownerEmail', data-group='people', checked)
              span Owner Email
            label.checkbox-item
              input.export-field(type='checkbox', data-key='team', data-group='people', checked)
              span Team Members
            label.checkbox-item
              input.export-field(type='checkbox', data-key='canonicalTeam', data-group='people', checked)
              span Canonical Team
          //- Media & Links
          .export-group-header
            span Media &amp; Links
            button.group-toggle(type='button', data-group='media') Deselect
          .checkbox-grid
            label.checkbox-item
              input.export-field(type='checkbox', data-key='logo', data-group='media', checked)
              span Logo
            label.checkbox-item
              input.export-field(type='checkbox', data-key='repoLinks', data-group='media', checked)
              span Repo Links
            label.checkbox-item
              input.export-field(type='checkbox', data-key='demoUrl', data-group='media', checked)
              span Demo URL
            label.checkbox-item
              input.export-field(type='checkbox', data-key='slidesUrl', data-group='media', checked)
              span Slides URL
            label.checkbox-item
              input.export-field(type='checkbox', data-key='externalLinks', data-group='media', checked)
              span External Links
            label.checkbox-item
              input.export-field(type='checkbox', data-key='asciinema', data-group='media', checked)
              span Asciinema Casts
            label.checkbox-item
              input.export-field(type='checkbox', data-key='videos', data-group='media', checked)
              span Videos
          //- Stats & Dates
          .export-group-header
            span Stats &amp; Dates
            button.group-toggle(type='button', data-group='stats') Deselect
          .checkbox-grid
            label.checkbox-item
              input.export-field(type='checkbox', data-key='avgRating', data-group='stats', checked)
              span Avg Rating
            label.checkbox-item
              input.export-field(type='checkbox', data-key='voteCount', data-group='stats', checked)
              span Vote Count
            label.checkbox-item
              input.export-field(type='checkbox', data-key='totalStars', data-group='stats', checked)
              span Total Stars
            label.checkbox-item
              input.export-field(type='checkbox', data-key='createdAt', data-group='stats', checked)
              span Created At
            label.checkbox-item
              input.export-field(type='checkbox', data-key='updatedAt', data-group='stats', checked)
              span Updated At
        .modal-footer
          button.btn.btn-neon-outline(type='button', data-bs-dismiss='modal') Cancel
          button#exportSubmitBtn.btn.btn-neon-cyan(type='button') Export

block scripts
  script(nonce=cspNonce).
    const catData = !{safeJson(categoryStats)};
    new Chart(document.getElementById('categoryChart'), {
      type: 'doughnut',
      data: {
        labels: catData.map(c => c._id),
        datasets: [{ data: catData.map(c => c.count),
          backgroundColor: ['#00d4ff','#ff006e','#8b00ff','#ff6600','#00ff88','#ffcc00','#ff4444','#44aaff','#cc44ff','#888888'] }]
      },
      options: { plugins: { legend: { labels: { color: '#c8e6ff', font: { size: 11 } } } } }
    });
    document.getElementById('resetConfirmInput').addEventListener('input', function () {
      const btn = document.getElementById('resetSubmitBtn');
      const hidden = document.getElementById('resetConfirmHidden');
      const val = this.value.trim();
      hidden.value = val;
      btn.disabled = val !== 'RESET';
    });
    document.querySelectorAll('.copy-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        navigator.clipboard.writeText(btn.dataset.url).then(() => {
          const orig = btn.textContent;
          btn.textContent = 'Copied!';
          setTimeout(() => { btn.textContent = orig; }, 1500);
        });
      });
    });
    // Dates form: convert stored UTC ISO values to local datetime-local on display,
    // and convert back to UTC ISO on submit — avoids server/browser timezone mismatch.
    (function () {
      var sectionInput = document.querySelector('form input[name="section"][value="dates"]');
      if (!sectionInput) return;
      var form = sectionInput.closest('form');
      // Convert a UTC ISO (or tz-naive) string to the local datetime-local value "YYYY-MM-DDTHH:mm"
      function utcToLocalInput(utcStr) {
        if (!utcStr) return '';
        var d = new Date(utcStr);
        if (isNaN(d.getTime())) return '';
        var localMs = d.getTime() - d.getTimezoneOffset() * 60000;
        return new Date(localMs).toISOString().slice(0, 16);
      }
      // Populate inputs from data-utc (handles both old tz-naive and new UTC ISO stored values)
      form.querySelectorAll('input[type="datetime-local"]').forEach(function (input) {
        input.value = utcToLocalInput(input.dataset.utc || '');
      });
      // Before submit: for each datetime-local input, create a hidden field with the
      // UTC ISO value and disable the visible input so only the hidden field is sent.
      // (Setting input.value to a full ISO string like "2026-05-13T15:00:00.000Z" would
      // be rejected by the browser — datetime-local only accepts "YYYY-MM-DDTHH:mm".)
      form.addEventListener('submit', function () {
        form.querySelectorAll('input[type="datetime-local"]').forEach(function (input) {
          var hidden = document.createElement('input');
          hidden.type = 'hidden';
          hidden.name = input.name;
          hidden.value = input.value ? new Date(input.value).toISOString() : '';
          form.appendChild(hidden);
          input.disabled = true;
        });
      });
    })();
    // Admin countdown status — live display in Event Dates card
    (function () {
      var el = document.getElementById('admin-countdown-status');
      if (!el) return;
      var hackStart  = el.dataset.hackathonStart ? new Date(el.dataset.hackathonStart) : null;
      var deadline   = el.dataset.deadline        ? new Date(el.dataset.deadline)       : null;
      var megademo   = el.dataset.megademo        ? new Date(el.dataset.megademo)       : null;
      function fmtRemaining(ms) {
        if (ms <= 0) return '0s';
        var totalSec = Math.floor(ms / 1000);
        var sec = totalSec % 60;
        var totalMin = Math.floor(totalSec / 60);
        var min = totalMin % 60;
        var totalHr = Math.floor(totalMin / 60);
        var hr  = totalHr % 24;
        var day = Math.floor(totalHr / 24);
        var parts = [];
        if (day) parts.push(day + 'd');
        if (hr)  parts.push(hr  + 'h');
        if (min) parts.push(min + 'm');
        parts.push(sec + 's');
        return parts.join(' ');
      }
      function update() {
        var now = Date.now();
        var label = '', remaining = '';
        if (hackStart && now < hackStart.getTime()) {
          label = 'Currently: Hackathon starts in ';
          remaining = fmtRemaining(hackStart.getTime() - now);
        } else if (deadline && now < deadline.getTime()) {
          label = 'Currently: Submissions close in ';
          remaining = fmtRemaining(deadline.getTime() - now);
        } else if (megademo && now < megademo.getTime()) {
          label = 'Currently: MegaDemo in ';
          remaining = fmtRemaining(megademo.getTime() - now);
        } else if (megademo && now >= megademo.getTime()) {
          el.innerHTML = 'Currently: <strong style="color:#00d4ff">MegaDemo is live (or past).</strong>';
          return;
        } else {
          el.textContent = 'No countdown dates configured.';
          return;
        }
        el.innerHTML = label + '<strong style="color:#00d4ff">' + remaining + '</strong>';
      }
      update();
      setInterval(update, 1000);
    })();
    // Banner char counter
    (function () {
      var ta = document.querySelector('textarea[name="announcementBanner"]');
      var counter = document.getElementById('banner-char-count');
      if (!ta || !counter) return;
      ta.addEventListener('input', function () { counter.textContent = ta.value.length; });
    })();

    // ── Export CSV modal logic ─────────────────────────────────────────────
    (function () {
      var selectAll = document.getElementById('exportSelectAll');
      var exportBtn = document.getElementById('exportSubmitBtn');
      var allFields = document.querySelectorAll('.export-field');
      var groupToggles = document.querySelectorAll('.group-toggle');

      function updateGroupToggle(group) {
        var fields = document.querySelectorAll('.export-field[data-group="' + group + '"]');
        var btn = document.querySelector('.group-toggle[data-group="' + group + '"]');
        if (!btn) return;
        var checked = 0;
        fields.forEach(function (f) { if (f.checked) checked++; });
        btn.textContent = checked === fields.length ? 'Deselect' : 'Select';
      }

      function updateSelectAll() {
        var checked = 0;
        allFields.forEach(function (f) { if (f.checked) checked++; });
        selectAll.checked = checked === allFields.length;
        selectAll.indeterminate = checked > 0 && checked < allFields.length;
      }

      selectAll.addEventListener('change', function () {
        var state = selectAll.checked;
        allFields.forEach(function (f) { f.checked = state; });
        groupToggles.forEach(function (btn) {
          btn.textContent = state ? 'Deselect' : 'Select';
        });
      });

      groupToggles.forEach(function (btn) {
        btn.addEventListener('click', function () {
          var group = btn.dataset.group;
          var fields = document.querySelectorAll('.export-field[data-group="' + group + '"]');
          var allChecked = true;
          fields.forEach(function (f) { if (!f.checked) allChecked = false; });
          var newState = !allChecked;
          fields.forEach(function (f) { f.checked = newState; });
          btn.textContent = newState ? 'Deselect' : 'Select';
          updateSelectAll();
        });
      });

      allFields.forEach(function (f) {
        f.addEventListener('change', function () {
          updateGroupToggle(f.dataset.group);
          updateSelectAll();
        });
      });

      exportBtn.addEventListener('click', function () {
        var keys = [];
        allFields.forEach(function (f) { if (f.checked) keys.push(f.dataset.key); });
        if (keys.length === 0) {
          alert('Select at least one field to export.');
          return;
        }
        var url = keys.length === allFields.length
          ? '/admin/export'
          : '/admin/export?fields=' + keys.join(',');
        window.location = url;
      });
    })();
