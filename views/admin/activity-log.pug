extends ../layout

block content
  .page-header
    h1.pixel-text ACTIVITY LOG
    a.btn.btn-neon-outline.me-2(href='/admin/guide') Admin Guide
    a.btn.btn-neon-outline(href='/admin') <- Admin Dashboard

  .d-flex.align-items-center.gap-2.mb-3
    a.btn.btn-neon-outline(href='/admin/activity-log') Refresh
    a.btn.btn-neon-outline(href='/admin/activity-log?format=text', download) Download

  .md-card
    if !entries || entries.length === 0
      p.text-muted No activity recorded yet.
    else
      .activity-log-scroll
        each entry in entries
          - const ts = entry.timestamp ? (() => { try { return new Date(entry.timestamp).toISOString(); } catch { return '??'; } })() : '??'
          .log-line
            span.log-ts= '[' + ts + '] '
            span.log-actor= entry.userEmail + ': '
            span.log-action= entry.action
