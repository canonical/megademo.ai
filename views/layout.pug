doctype html
html.h-100(lang='en-GB')
  head
    meta(charset='utf-8')
    meta(http-equiv='X-UA-Compatible', content='IE=edge')
    meta(name='viewport', content='width=device-width, initial-scale=1.0')
    meta(name='csrf-token', content=_csrf)
    title #{title} — MegaDemo.ai
    link(rel='icon', type='image/svg+xml', href='/favicon.svg')
    link(rel='preconnect', href='https://fonts.googleapis.com')
    link(rel='preconnect', href='https://fonts.gstatic.com', crossorigin)
    link(rel='stylesheet', href='https://fonts.googleapis.com/css2?family=Black+Ops+One&family=Jersey+10+Charted&family=Press+Start+2P&family=JetBrains+Mono:wght@400;500;700&display=swap')
    link(rel='stylesheet', href='/css/main.css?v=' + assetVersion)
    block head

  body.d-flex.flex-column.h-100
    include partials/header

    main.flex-shrink-0
      .container.mt-4
        include partials/flash
        block content

    include partials/footer

    script(src='https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js', integrity='sha384-1H217gwSVyLSIfaLxHbE7dRb3v4mYCKbpQvzx0cegeju1MVsGrX5xXxAvs/HgeFs', crossorigin='anonymous', nonce=cspNonce)
    script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js', integrity='sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz', crossorigin='anonymous', nonce=cspNonce)
    script(src='/js/main.js', nonce=cspNonce)
    block scripts
