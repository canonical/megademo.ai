{
  "name": "megademo-ai",
  "version": "1.0.0",
  "description": "Canonical AI Hackathon — MegaDemo.ai project showcase",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "scss": "sass --no-source-map --silence-deprecation=import --quiet-deps --load-path=./ --update ./public/css:./public/css",
    "start": "npm run scss && node app.js",
    "dev": "node scripts/dev-start.js",
    "lint": "eslint \"**/*.js\" --fix",
    "lint-check": "eslint \"**/*.js\"",
    "load-test": "BASE_URL=${BASE_URL:-http://localhost:8080} npx artillery run scripts/load-test.yml",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --forceExit",
    "prepare": "[ \"$NODE_ENV\" = 'production' ] || husky"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@node-rs/bcrypt": "^1.10.7",
    "axios": "^1.15.2",
    "bootstrap": "^5.3.8",
    "chart.js": "^4.5.1",
    "compression": "^1.8.1",
    "connect-mongo": "^6.0.0",
    "errorhandler": "^1.5.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "express-session": "^1.19.0",
    "file-type": "^22.0.1",
    "helmet": "^8.1.0",
    "jquery": "^4.0.0",
    "js-yaml": "^4.1.1",
    "lusca": "^1.7.0",
    "marked": "^18.0.4",
    "mongoose": "^9.4.1",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "openid-client": "^6.8.4",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "pug": "^3.0.4",
    "sanitize-html": "^2.17.4",
    "sass": "^1.99.0",
    "validator": "^13.15.35"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "artillery": "^2.0.30",
    "eslint": "^10.2.0",
    "globals": "^17.0.0",
    "husky": "^9.1.7",
    "jest": "^30.0.0",
    "mongodb-memory-server": "^11.0.1",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=20.12.0"
  },
  "overrides": {
    "uuid": "^14.0.0",
    "fast-xml-parser": "^5.7.2"
  }
}
