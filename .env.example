# MegaDemo.ai — Environment Variables
# Copy to .env and fill in values

BASE_URL=http://localhost:8080
MONGODB_URI=mongodb://localhost:27017/megademo
SESSION_SECRET=change-this-to-a-random-string-in-production

# ── Authentication ──────────────────────────────────────────────────────────
# AUTH_MODE selects the authentication provider.
#   github  (default) – GitHub OAuth; requires GITHUB_CLIENT_ID/SECRET below.
#   oidc              – Canonical IdP (OIDC); requires OIDC_* vars below.
AUTH_MODE=github

# GitHub OAuth (required when AUTH_MODE=github or unset)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Canonical IdP / OIDC (required only when AUTH_MODE=oidc)
# OIDC_ISSUER_URL=https://login.ubuntu.com
# OIDC_CLIENT_ID=your_oidc_client_id
# OIDC_CLIENT_SECRET=your_oidc_client_secret

# Optional: GitHub token for repo stats (increases rate limit from 60 to 5000 req/hr)
GITHUB_TOKEN=

# Optional: Mattermost incoming webhook URL
MATTERMOST_WEBHOOK_URL=

# Optional: Kiosk slide interval in seconds (default: 30)
KIOSK_INTERVAL=30

# Mattermost daily summary cron schedule (default: 08:00, 12:00, 17:00 UTC)
# Standard cron expression — set to 'disabled' to turn off
SUMMARY_CRON=0 8,12,17 * * *

# Rate limiting
RATE_LIMIT_GLOBAL=500
RATE_LIMIT_AUTH=20

# Node environment
NODE_ENV=development
PORT=8080
