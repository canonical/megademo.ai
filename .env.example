# MegaDemo.ai — Environment Variables
# Copy to .env and fill in values

BASE_URL=http://localhost:8080
MONGODB_URI=mongodb://localhost:27017/megademo
SESSION_SECRET=change-this-to-a-random-string-in-production

# ---------------------------------------------------------------------------
# Authentication — choose ONE of the two options below
# ---------------------------------------------------------------------------

# Option A: OIDC via Canonical Identity Platform (recommended for production)
# When OIDC_ISSUER_URL is set:
#   - Entire site is gated (all routes except /auth/* and /kiosk* require login)
#   - GitHub OAuth (Option B) is bypassed entirely
#   - GITHUB_CLIENT_ID / GITHUB_CLIENT_SECRET are not used by this app
#
# Steps to activate:
#   1. Ask IS to register MegaDemo.ai as a Hydra client.
#      Redirect URI: BASE_URL + /auth/oidc/callback
#      Scopes:       openid profile email
#   2. IS provides OIDC_CLIENT_ID + OIDC_CLIENT_SECRET
#   3. Set all three vars below and redeploy
#
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# Option B: Direct GitHub OAuth (used when OIDC_ISSUER_URL is not set)
# Create at https://github.com/settings/developers → OAuth Apps
# Authorized callback URL: BASE_URL + /auth/github/callback
# The app verifies Canonical membership in three ways (in order):
#   1. /user/memberships/orgs/canonical API  (fails if org has OAuth App restrictions)
#   2. /user/orgs list                        (also fails if org restricts OAuth apps)
#   3. @canonical.com email domain        (opt-in fallback; enable with ALLOW_CANONICAL_EMAIL_FALLBACK=true)
GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret
ALLOW_CANONICAL_EMAIL_FALLBACK=true

# ---------------------------------------------------------------------------

# Optional: GitHub token for repo stats (increases rate limit from 60 to 5000 req/hr)
GITHUB_TOKEN=

# Optional: Mattermost incoming webhook URL
MATTERMOST_WEBHOOK_URL=

# Optional: Kiosk slide interval in seconds (default: 30)
KIOSK_INTERVAL=30

# Mattermost daily summary cron schedule (default: 08:00, 12:00, 17:00 UTC)
# Standard cron expression — set to 'disabled' to turn off
SUMMARY_CRON=0 8,12,17 * * *

# Rate limiting
RATE_LIMIT_GLOBAL=500
RATE_LIMIT_AUTH=20

# Node environment
NODE_ENV=development
PORT=8080
